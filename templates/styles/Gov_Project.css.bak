
/* Filename: Gov_Project.css */

body {
    font-family: Arial, Helvetica, sans-serif; 
    line-height: 1.6; 
    color: #222222; 
    background-color: #ffffff; 
    background-attachment: fixed;
    /background-position: center center;
}

.current {
    color: #ffffff; 
    font-weight: bold; 
}


div#Container{
    padding: 10px;
    width: 800px ;
    margin: 15px auto;
    background-color: #ffffff;
	
}

div#Container img {
	width: 100px;
}

header {
    text-align: center; 
	 background-image: url("../images/Cover_Image.png");
	  background-repeat: no-repeat;
    background-size: Window;
	
	
}



 div#imageHead{
	width: 100%;
position: center;
}

 header h1{
   margin-top: 0.5rem;
   text-shadow: 0px 1px 1px rgba(0,0,0,0.30);
 }

nav {
   background-color: green; 
    text-align: center; 
    padding: 0.5rem 0.75rem 0.5rem 0.75rem;
    border-bottom-left-radius: 0.5rem;
    border-bottom-right-radius: 0.5rem;
	width: 726px;
}

nav a, nav .current{
    padding: 10px;
    width: 800px ;
    margin: 15px auto;
    border-radius: 0.375rem;
}


 main a:hover, {
    background-color: rgba(255,255,255,0.12);
	color: blue;
 }

nav .current {
	color: white;
	font-size: 27px;
}

 main section{
    margin: 0.5rem;
    padding: 1rem 1.25rem 1rem 1.25rem;
    border: 1px solid #e5e7eb;
    box-shadow: 0px 2px 10px rgba(0,0,0,0.06);
 }
 
 main p {
	 font-size: 20px;
 }
	
main h1 {
		text-align: center;	
 }

main h2 {
    color: #0f766e; 
    font-variant: small-caps; 
}

h2 a {
	text-decoration: none;
	color: #2a9d8f;
}



form#Login input {
	margin: 10px;
	padding: 8px;
	border-radius: 4px;

}

form#LogForm {
	display: grid;
	margin: auto;
	gap: 0.5em;
	width: fit-content;
	
}

section#Permits blockquote{
   margin: 0.75rem 0 0.75rem;
    padding: 1rem;
    background-color: #f8fafc;
    border-left: 6px solid #0f766e;
}

section#Licences blockquote q {
    font-style: italic; 
}




footer {
    text-align: right; 
    font-size: 0.8rem; 
}
   
	footer {
   margin-top: 1.5rem;
    background: #f8fafc;
    border-top: 3px solid #e5e7eb;
	padding: 0.75rem;
	}


    footer a:link, footer a:visited {
        color: #0f766e; 
    }
